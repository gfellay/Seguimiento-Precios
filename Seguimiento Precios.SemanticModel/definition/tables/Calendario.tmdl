	partition Calendario = m
		mode: import
		source =
				let
				    fHoy = DateTime.Date(DateTime.LocalNow()),
				    fMin = List.Min(compras[fecha]),
				    fDesde = #date(Date.Year(fMin),1,1),
				    fHasta = #date(Date.Year(fHoy),12,31),
				
				    Source = fnCalendario(fDesde, fHasta)
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

