expression fnCalendario = ```
		// Función: fnCalendario
		// Parámetros: FechaInicio (date), FechaFin (date)
		
		(fnFechaInicio as date, fnFechaFin as date) as table =>
		let
		
		    // 1. Crear lista de fechas
		    ListaFechas = List.Dates(
		        fnFechaInicio,
		        Duration.Days(fnFechaFin - fnFechaInicio) + 1,
		        #duration(1,0,0,0)
		    ),
		
		    // 2. Convertir a tabla
		    TablaBase = Table.FromList(ListaFechas, Splitter.SplitByNothing(), {"Fecha"}, null),
		    
		    // 3. Agregar columnas derivadas
		    AgregarColumnas = Table.TransformColumns(TablaBase, {{"Fecha", Date.From}}),
		    TablaExpandida = Table.AddColumn(AgregarColumnas, "Año", each Date.Year([Fecha]), Int64.Type),
		    TablaMes = Table.AddColumn(TablaExpandida, "Mes", each Date.Month([Fecha]), Int64.Type),
		    TablaNombreMes = Table.AddColumn(TablaMes, "NombreMes", each Date.MonthName([Fecha]), type text),
		    TablaTrimestre = Table.AddColumn(TablaNombreMes, "Trimestre", each Date.QuarterOfYear([Fecha]), Int64.Type),
		    TablaSemanaISO = Table.AddColumn(TablaTrimestre, "SemanaISO", each Date.WeekOfYear([Fecha], Day.Monday), Int64.Type),
		    TablaNombreDia = Table.AddColumn(TablaSemanaISO, "NombreDía", each Date.DayOfWeekName([Fecha]), type text),
		    TablaDiaSemana = Table.AddColumn(TablaNombreDia, "DíaSemana", each Date.DayOfWeek([Fecha], Day.Monday) + 1, Int64.Type),
		
		    // 4. Ordenar columnas
		    TablaFinal = Table.SelectColumns(
		        TablaDiaSemana,
		        {"Fecha","Año","Mes","NombreMes","Trimestre","SemanaISO","NombreDía","DíaSemana"}
		    )
		
		in
		    TablaFinal
		```
	lineageTag: e4025a1f-06ae-4f34-9b94-e0d6461b47fd

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

/// Para agrupar las tiendas (en caso que se hagan compras en más de una tienda para una cadena)
expression cadenas =
		let
		    Source = PostgreSQL.Database("localhost", "Pruebas"),
		    public_cadenas = Source{[Schema="public",Item="cadenas"]}[Data],
		    #"Removed Columns" = Table.RemoveColumns(public_cadenas,{"public.tiendas"})
		in
		    #"Removed Columns"
	lineageTag: b764d304-ef99-4d43-b56d-0874a903fde3

	annotation PBI_NavigationStepName = Navigation

